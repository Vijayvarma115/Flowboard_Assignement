# Database (Railway PostgreSQL plugin auto-fills this)
DATABASE_URL="postgresql://postgres:password@localhost:5432/flowboard"

# JWT Secret (generate a strong random string)
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Server Port
PORT=3000

# Frontend URL (replace with your Railway frontend URL)
FRONTEND_URL="http://localhost:5173"

# Email Configuration (Gmail SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="FlowBoard <your-gmail@gmail.com>"
SMTP_SECURE=false

# Node Environment
NODE_ENV="production"
